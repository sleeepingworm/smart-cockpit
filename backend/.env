# ===== 数据库配置 =====
MYSQL_URL=mysql+pymysql://root:123456@127.0.0.1:3307/cockpit_db?charset=utf8mb4
# ===== Redis配置（Day8后才用，先留着）=====
REDIS_URL=redis://localhost:6379/0
# ===== JWT认证配置（Day3用，先占位）=====
JWT_SECRET=647b591353c75bbfd66f52221bea0f173459ef82f333ea966ca79b7698dc38993c6fc54fd28118398f7a7d6bfa12a39f5829d2f14595559beee131c8b955a926
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
# ===== CORS允许的前端源 =====
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
# ===== 上传文件目录 =====
UPLOAD_DIR=uploads
# ===== 调试模式（true=打印SQL日志）=====
DEBUG=true
# 高德地图 Web 服务 Key（推荐配置；未配置时定位/天气自动降级为 mock）
AMAP_KEY=0d2746ac08cd211b10130ed9b787c80e

# 传感器串口（有 STM32 硬件时启用，否则 false 走 mock）
SENSOR_ENABLED=false
SENSOR_PORT=COM3
SENSOR_BAUDRATE=115200
SENSOR_DATA_TTL=5

# ===== Day10: 障碍物检测（YOLO） =====
# 模型路径（相对 backend/；支持 .pt / .onnx / .engine）
OBSTACLE_MODEL_PATH=ai/ai_models/yolo26n.pt
OBSTACLE_IMGSZ=640           # 推理分辨率
OBSTACLE_CONF=0.35           # 置信度阈值
OBSTACLE_IOU=0.50            # NMS IoU 阈值
OBSTACLE_DEVICE=cpu          # cpu / 0 / cuda:0
OBSTACLE_HALF=false          # FP16 半精度（GPU 才有意义）
# 类别白名单（空=默认驾驶集；*=全80类；或逗号分隔英文类名）
OBSTACLE_CLASSES=
# 告警类别（只对这些类触发写库告警）
OBSTACLE_ALERT_CLASSES=person,bicycle,motorcycle
OBSTACLE_ALERT_FRAMES=5      # 连续 N 帧命中才算有效
OBSTACLE_ALERT_COOLDOWN=30   # 两次告警最短间隔秒数